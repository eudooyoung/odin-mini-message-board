<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= title %></title>
  </head>
  <body>
    <%- include("partials/header") %>
    <h2>Message Input</h2>
    <form action="/new" method="post">
      <label for="author">Author: </label>
      <input
        type="text"
        id="author"
        name="author"
        value="<%= locals.prev && prev.author %>"
        required
      />
      <label for="message">Message: </label>
      <input
        type="text"
        id="text"
        name="text"
        value="<%= locals.prev && prev.text %>"
        required
      />
      <button type="submit">Send</button>
    </form>
    <%- include("partials/errors") %>
  </body>
</html>
